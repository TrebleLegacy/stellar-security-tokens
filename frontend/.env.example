# API URL
VITE_API_URL=http://localhost:3000/api

# Stellar Network Configuration
# Set to 'testnet' or 'public' (mainnet)
VITE_STELLAR_NETWORK=testnet

# Stellar Passkey Kit Configuration
# These will be auto-configured based on VITE_STELLAR_NETWORK if not set
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_FACTORY_CONTRACT_ID=CBKZRF5QVDPXFBPWGUBIHXUJGYJFSCNRLMHKD2FNMKQH2HYBBKPINNEX

# For Mainnet, use:
# VITE_STELLAR_NETWORK=public
# VITE_SOROBAN_RPC_URL=https://soroban-rpc.mainnet.stellar.org
# VITE_STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
# VITE_FACTORY_CONTRACT_ID=<mainnet-factory-contract-id>
